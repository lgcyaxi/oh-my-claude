# Auto detect text files and perform LF normalization
* text=auto

# Git LFS - large binary files
apps/wezterm/**/*.exe filter=lfs diff=lfs merge=lfs -text
apps/wezterm/**/*.dll filter=lfs diff=lfs merge=lfs -text
apps/menubar/builds/**/*.exe filter=lfs diff=lfs merge=lfs -text
apps/menubar/builds/**/omc-menubar filter=lfs diff=lfs merge=lfs -text
apps/wezterm/**/mesa/*.dll filter=lfs diff=lfs merge=lfs -text
